# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.1

# Database Configuration
DATABASE_URL=sqlite:///data/market_intelligence.db
REDIS_URL=redis://localhost:6379

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Crew AI Configuration
CREW_VERBOSE=true
CREW_MEMORY=true
CREW_PROCESS=sequential

# Data Collection Configuration
DATA_COLLECTION_TIMEOUT=30
DATA_COLLECTION_RETRIES=3
DATA_CACHE_TTL=3600

# Monitoring Configuration
MONITORING_INTERVAL=3600
MONITORING_ENABLED=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Security Configuration
CORS_ORIGINS=["*"]
API_KEY_HEADER=X-API-Key

# External API Keys (for production use)
YAHOO_FINANCE_API_KEY=your_yahoo_finance_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
NEWS_API_KEY=your_news_api_key_here
TWITTER_API_KEY=your_twitter_api_key_here

# File Paths
DATA_DIRECTORY=data
REPORTS_DIRECTORY=reports
LOGS_DIRECTORY=logs

# Performance Configuration
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=60

# Analysis Configuration
ANALYSIS_CONFIDENCE_THRESHOLD=0.7
TREND_PREDICTION_HORIZON=24 