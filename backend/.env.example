OPENAI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_TTS_CREDENTIALS_JSON=
GOOGLE_STT_CREDENTIALS_JSON=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=story-audio
AZURE_SAS_EXPIRY_HOURS=24
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DEBUG=false

STORY_PRIMARY_PROVIDER=openai
STORY_PRIMARY_MODEL=gpt-5.4-mini
STORY_FALLBACK_PROVIDER=google
STORY_FALLBACK_MODEL=gemma-4
STORY_TIMEOUT_SECONDS=45

REASONING_PRIMARY_PROVIDER=openai
REASONING_PRIMARY_MODEL=gpt-5.4-mini
REASONING_FALLBACK_PROVIDER=google
REASONING_FALLBACK_MODEL=gemma-4
REASONING_TIMEOUT_SECONDS=20

STT_PRIMARY_PROVIDER=openai
STT_PRIMARY_MODEL=gpt-4o-transcribe
STT_FALLBACK_PROVIDER=google
STT_FALLBACK_MODEL=chirp_2
STT_TIMEOUT_SECONDS=20

TTS_PRIMARY_PROVIDER=elevenlabs
TTS_PRIMARY_MODEL=eleven_multilingual_v2
TTS_FALLBACK_PROVIDER=google
TTS_FALLBACK_MODEL=Neural2
TTS_TIMEOUT_SECONDS=30

ELEVENLABS_API_KEY=
ELEVENLABS_MALE_VOICE_ID=
ELEVENLABS_FEMALE_VOICE_ID=

VOICE_WAKE_PHRASE=hey jarvis
VOICE_REQUIRE_WAKE_PHRASE=false
VOICE_COMMAND_CONFIDENCE_THRESHOLD=0.6
VOICE_MAX_AUDIO_BYTES=5242880
LOCAL_MEDIA_URL_BASE=/media

CB_FAILURE_THRESHOLD=3
CB_RECOVERY_TIMEOUT_SECONDS=60
