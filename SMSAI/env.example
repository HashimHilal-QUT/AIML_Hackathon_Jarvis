# Copy this to .env and fill values

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Integrations toggles (set one or both to true)
USE_TWILIO=true
USE_PLAYSMS=false

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+61xxxxxxxxx

# PlaySMS
PLAYSMS_API_URL=http://localhost/playsms
PLAYSMS_API_KEY=your_playsms_api_key
PLAYSMS_SENDER_ID=YourSIM

# Server
PORT=5000

# Ngrok (optional but recommended for auth'd regions)
NGROK_AUTHTOKEN=your_ngrok_authtoken
